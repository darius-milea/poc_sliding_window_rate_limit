# Backend mode: in-memory or redis
RATE_LIMIT_BACKEND=redis

# Single Redis node (non-cluster)
REDIS_KEY_PREFIX=rl:poc

# Safety TTL for in-flight concurrency permits (milliseconds)
REDIS_CONCURRENCY_LEASE_MS=1800000

# Optional policy override for recipient cap per message
ALLOW_UP_TO_1000_RECIPIENTS_PER_MESSAGE=true

# REDIS >>>
REDIS_CLUSTER=false
REDIS_HOST=localhost
REDIS_USER=dev-zenithmaster
REDIS_PASSWORD=REDISPASSWORD
REDIS_PORT=6376
REDIS_HEALTH_TIMEOUT=500
# <<< REDIS
